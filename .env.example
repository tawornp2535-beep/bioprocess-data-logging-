# Copy this file to .env and fill in your MongoDB Atlas connection string.
# Example format (SRV):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.abcd1.mongodb.net/mydatabase?retryWrites=true&w=majority

# If you don't use Atlas and prefer local file storage, leave MONGODB_URI empty.
MONGODB_URI=

# Optional: change server port
# PORT=5000
